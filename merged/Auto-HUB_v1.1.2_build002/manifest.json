{
  "manifestVersion": 6,
  "id": "com.psautohub.panel",
  "name": "Auto-HUB",
  "version": "1.1.2",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "26.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "batchPanel",
      "label": {
        "default": "Auto-HUB"
      },
      "minimumSize": {
        "width": 360,
        "height": 520
      },
      "maximumSize": {
        "width": 760,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 760
      },
      "preferredFloatingSize": {
        "width": 640,
        "height": 760
      }
    }
  ],
  "requiredPermissions": {
    "clipboard": "readAndWrite",
    "localFileSystem": "fullAccess",
    "allowCodeGenerationFromStrings": true
  }
}
