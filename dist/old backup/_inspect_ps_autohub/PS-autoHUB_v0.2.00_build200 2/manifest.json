{
  "manifestVersion": 6,
  "id": "com.psautohub.panel",
  "name": "PS-autoHUB",
  "version": "0.2.00",
  "main": "index.html",
  "host": [
    {
      "app": "PS",
      "minVersion": "26.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "batchPanel",
      "label": {
        "default": "PS-autoHUB"
      },
      "minimumSize": {
        "width": 300,
        "height": 500
      },
      "maximumSize": {
        "width": 600,
        "height": 1200
      },
      "preferredDockedSize": {
        "width": 320,
        "height": 700
      }
    }
  ],
  "requiredPermissions": {
    "clipboard": "readAndWrite",
    "localFileSystem": "fullAccess",
    "allowCodeGenerationFromStrings": true
  }
}
